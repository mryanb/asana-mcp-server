# Required: Asana personal access token or service account token
ASANA_ACCESS_TOKEN=

# Optional: Workspace GID (auto-detected from authenticated user if omitted)
# ASANA_WORKSPACE_GID=

# Optional: Default number of results per query (default: 50)
# ASANA_MCP_DEFAULT_LIMIT=50

# Optional: Maximum allowed result limit (default: 200)
# ASANA_MCP_MAX_LIMIT=200

# Optional: Readonly mode — true by default. Set to false to enable write tools.
# ASANA_MCP_READONLY=true

# Optional: Restrict reads to specific project GIDs (comma-separated).
# ASANA_MCP_PROJECT_ALLOWLIST=1234567890,0987654321

# Optional: Restrict writes to specific project GIDs (comma-separated).
# Requires ASANA_MCP_READONLY=false. Omit to allow writes to all projects.
# Use "*" to allow writes to all projects (same as omitting).
# ASANA_MCP_WRITE_ALLOWLIST=1234567890

# Optional: Allow writes on tasks assigned to the authenticated user, even if
# the task has no project (e.g. inbox/My Tasks items). Only relevant when
# write_allowlist is configured. Default: false.
# ASANA_MCP_ALLOW_WRITE_MY_TASKS=false

# Optional: Enable task deletion. Disabled by default — separate from general write access.
# ASANA_MCP_ALLOW_DELETE=false

# Optional: Log level - debug, info, warning, error (default: info)
# ASANA_MCP_LOG_LEVEL=info

# Optional: JSONL log file for structured tool call logging.
# Each line records: tool name, args, duration_ms, status (ok/error/blocked), and any error.
# Useful for performance monitoring and debugging. Agents can read this file to review patterns.
# Default location when enabled: ~/.asana-mcp-server/logs/tool-calls.jsonl
# ASANA_MCP_LOG_FILE=

# --- 1Password integration ---
# To use 1Password for credential injection:
#
# OP_SERVICE_ACCOUNT_TOKEN="$(security find-generic-password -s openclaw-op-service-token -w)" \
# ASANA_ACCESS_TOKEN="op://Bots/Asana MCP/access_token" \
# op run -- node dist/index.js
